# Copy this file to .env on Windows Server.
# Adjust passwords and LibreOffice path before starting the website.

APP_HOST=0.0.0.0
APP_PORT=8088
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# Python launcher folder supplied by the Windows Server.
PYTHON_LAUNCHER_DIR=C:\Users\Administrator\AppData\Local\Programs\Python\Launcher

# The application uses paths relative to the project by default.
# Override only when you intentionally want data outside the project folder.
# DATA_DIR=C:\Users\Administrator\Downloads\esin\codex\app\data
# UPLOAD_DIR=C:\Users\Administrator\Downloads\esin\codex\app\uploads
# GENERATED_DIR=C:\Users\Administrator\Downloads\esin\codex\app\generated
# OUTPUTS_DIR=C:\Users\Administrator\Downloads\esin\codex\outputs

# Install LibreOffice on Windows Server and set the real soffice path if auto-detection fails.
# Common values:
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.com

LIBREOFFICE_PROFILE_DIR=C:\Users\Administrator\Downloads\esin\codex\outputs\.lo-profile-windows
